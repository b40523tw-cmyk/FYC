<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>業績與薪水計算工具</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    /* 隱藏預設的 input number 上下箭頭 */
    input[type=number]::-webkit-inner-spin-button, 
    input[type=number]::-webkit-outer-spin-button { 
      -webkit-appearance: none; 
      margin: 0; 
    }
    input[type=number] {
      -moz-appearance: textfield;
    }
  </style>
</head>
<body class="bg-gray-50 text-gray-800 font-sans min-h-screen relative p-4 md:p-8">

  <!-- 浮動提示 (Toast) -->
  <div id="toast" class="fixed top-4 left-1/2 transform -translate-x-1/2 z-50 bg-gray-800 text-white px-6 py-3 rounded-full shadow-lg transition-opacity duration-300 opacity-0 pointer-events-none">
    提示訊息
  </div>

  <!-- 管理員登入視窗 -->
  <div id="adminModal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-40 hidden">
    <div class="bg-white p-6 rounded-xl shadow-xl max-w-sm w-full">
      <h3 class="text-lg font-bold mb-4">管理員驗證</h3>
      <p class="text-sm text-gray-500 mb-4">請輸入密碼以開啟費率表上傳功能。</p>
      <input 
        type="password" 
        id="adminCode"
        class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 mb-4"
        placeholder="輸入密碼"
      />
      <div class="flex justify-end space-x-2">
        <button id="cancelAdminBtn" class="px-4 py-2 text-gray-500 hover:bg-gray-100 rounded-lg">取消</button>
        <button id="submitAdminBtn" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">解鎖</button>
      </div>
    </div>
  </div>

  <div class="max-w-5xl mx-auto space-y-6">
    <!-- 標題與雲端狀態 -->
    <div class="flex justify-between items-end border-b pb-4">
      <h1 class="text-2xl font-bold text-gray-900">業績與薪水計算工具</h1>
      <div class="text-sm" id="cloudStatus">
        <span class="text-gray-400">連線中...</span>
      </div>
    </div>
    
    <!-- CSV 匯入區塊 (管理員可見) -->
    <div id="adminSection" class="hidden bg-blue-50 p-4 rounded-xl shadow-sm border border-blue-100 flex-col sm:flex-row sm:items-center justify-between gap-4">
      <div>
        <h2 class="text-md font-semibold text-blue-900">👑 管理員模式：更新雲端代理費率表 (CSV)</h2>
        <p class="text-sm text-blue-700">上傳後，所有使用此工具的人皆會同步取得最新費率。</p>
      </div>
      <div>
        <input 
          type="file" 
          id="fileUpload"
          accept=".csv" 
          class="block w-full text-sm text-blue-600 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-white file:text-blue-700 hover:file:bg-blue-100 cursor-pointer"
        />
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- 左側輸入區塊 -->
      <div class="md:col-span-1 bg-white p-6 rounded-xl shadow-sm border border-gray-100 space-y-4">
        <h2 class="text-lg font-semibold mb-4">輸入商品資訊</h2>
        
        <datalist id="product-list"></datalist>

        <div class="grid grid-cols-5 gap-2">
          <div class="col-span-3">
            <label class="block text-sm font-medium text-gray-700 mb-1">商品名稱</label>
            <input 
              type="text" 
              id="productName"
              list="product-list"
              value="愛得利"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
              placeholder="例如：愛得利"
            />
          </div>
          <div class="col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-1">年期</label>
            <input 
              type="number" 
              id="term"
              value="20"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
              placeholder="20"
            />
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">商品費用 (元)</label>
          <input 
            type="number" 
            id="fee"
            value="120000"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
            placeholder="120000"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            代理率 (%)
            <span id="autoFillBadge" class="hidden ml-2 text-xs text-green-600 font-medium bg-green-50 px-1.5 py-0.5 rounded">自動帶入</span>
          </label>
          <input 
            type="number" 
            id="agentRate"
            value="80"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
            placeholder="80"
          />
        </div>

        <div class="grid grid-cols-5 gap-2">
          <div class="col-span-3">
            <label class="block text-sm font-medium text-gray-700 mb-1">職級</label>
            <select 
              id="rank"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white"
            >
              <!-- 選項將由 JS 動態生成 -->
            </select>
          </div>
          <div class="col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-1">K值 (%)</label>
            <input 
              type="number" 
              id="kValue"
              value="68"
              readonly
              class="w-full px-3 py-2 border border-gray-300 rounded-lg bg-gray-100 text-gray-500 cursor-not-allowed focus:outline-none"
              placeholder="68"
            />
          </div>
        </div>

        <!-- 即時試算結果 -->
        <div class="mt-6 bg-blue-50 p-4 rounded-lg">
          <h3 class="text-sm font-semibold text-blue-900 mb-2">單筆試算結果</h3>
          <div class="space-y-1 text-sm">
            <div class="flex justify-between">
              <span class="text-blue-700">FYC (元)</span>
              <span id="currentFycText" class="font-medium">0 元</span>
            </div>
            <div class="flex justify-between">
              <span class="text-blue-700">FYC (C數)</span>
              <span id="currentCText" class="font-medium text-lg">0.00 C</span>
            </div>
            <div class="flex justify-between pt-2 border-t border-blue-200 mt-2">
              <span class="text-blue-900 font-bold">預估薪水</span>
              <span id="currentSalaryText" class="text-blue-900 font-bold text-xl">0 元</span>
            </div>
          </div>
        </div>

        <button 
          id="addRecordBtn"
          class="w-full mt-4 bg-blue-600 text-white font-medium py-2 px-4 rounded-lg hover:bg-blue-700 transition-colors"
        >
          新增至清單
        </button>
      </div>

      <!-- 右側清單與總計區塊 -->
      <div class="md:col-span-2 bg-white p-6 rounded-xl shadow-sm border border-gray-100 flex flex-col h-full">
        <h2 class="text-lg font-semibold mb-4">業績清單與總計</h2>
        
        <div class="grid grid-cols-2 gap-4 mb-6">
          <div class="bg-gray-50 p-4 rounded-lg border border-gray-200">
            <div class="text-sm text-gray-500 mb-1">總計 C數</div>
            <div id="totalCText" class="text-2xl font-bold text-gray-800">0.00 C</div>
          </div>
          <div class="bg-green-50 p-4 rounded-lg border border-green-200">
            <div class="text-sm text-green-700 mb-1">總計薪水</div>
            <div id="totalSalaryText" class="text-2xl font-bold text-green-800">0 元</div>
          </div>
        </div>

        <div class="flex-1 overflow-auto flex flex-col">
          <div id="emptyListState" class="flex-1 flex items-center justify-center text-gray-400 text-sm py-10">
            目前尚未新增任何業績紀錄
          </div>
          <div id="recordsContainer" class="space-y-3 hidden">
            <!-- 列表內容由 JS 生成 -->
          </div>

          <!-- 分頁控制區塊 -->
          <div id="paginationContainer" class="hidden flex justify-between items-center mt-4 pt-4 border-t border-gray-100">
            <button id="prevPageBtn" class="px-4 py-2 text-sm bg-gray-100 text-gray-600 rounded-lg hover:bg-gray-200 disabled:opacity-50 transition-colors">上一頁</button>
            <span id="pageInfoText" class="text-sm text-gray-500 font-medium">第 1 頁，共 1 頁</span>
            <button id="nextPageBtn" class="px-4 py-2 text-sm bg-gray-100 text-gray-600 rounded-lg hover:bg-gray-200 disabled:opacity-50 transition-colors">下一頁</button>
          </div>
        </div>
      </div>
    </div>

    <!-- 隱藏的管理員登入入口 -->
    <div class="flex justify-end mt-4">
      <button 
        id="showAdminBtn"
        class="text-xs text-gray-300 hover:text-gray-500 transition-colors"
      >
        管理員登入
      </button>
    </div>

  </div>

  <script type="module">
    import { initializeApp } from 'https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js';
    import { getAuth, signInAnonymously, onAuthStateChanged, signInWithCustomToken } from 'https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js';
    import { getFirestore, doc, setDoc, onSnapshot } from 'https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js';

    // 系統變數
    let user = null;
    let isAdmin = false;
    let catalog = [];
    let records = [];
    let currentPage = 1;
    const ITEMS_PER_PAGE = 10;
    
    // 職級設定
    const RANK_OPTIONS = [
      { name: '業務副總', k: 78 },
      { name: '業務總監', k: 75 },
      { name: '業務高經', k: 73 },
      { name: '業務經理', k: 68 },
      { name: '業務襄理', k: 58 },
      { name: '業務專員', k: 48 },
      { name: '業務代表', k: 40 },
    ];

    // 初始化 Firebase (根據執行環境抓取設定)
    const firebaseConfig = typeof __firebase_config !== 'undefined' ? JSON.parse(__firebase_config) : {};
    const appId = typeof __app_id !== 'undefined' ? __app_id : 'default-app-id';
    
    let db, auth;
    try {
      const app = initializeApp(firebaseConfig);
      auth = getAuth(app);
      db = getFirestore(app);
    } catch (e) {
      console.warn("Firebase 未能初始化，功能將以本地端模式運行", e);
    }

    // DOM 元素選取
    const els = {
      productName: document.getElementById('productName'),
      term: document.getElementById('term'),
      fee: document.getElementById('fee'),
      agentRate: document.getElementById('agentRate'),
      rank: document.getElementById('rank'),
      kValue: document.getElementById('kValue'),
      currentFycText: document.getElementById('currentFycText'),
      currentCText: document.getElementById('currentCText'),
      currentSalaryText: document.getElementById('currentSalaryText'),
      addRecordBtn: document.getElementById('addRecordBtn'),
      autoFillBadge: document.getElementById('autoFillBadge'),
      productList: document.getElementById('product-list'),
      
      totalCText: document.getElementById('totalCText'),
      totalSalaryText: document.getElementById('totalSalaryText'),
      emptyListState: document.getElementById('emptyListState'),
      recordsContainer: document.getElementById('recordsContainer'),
      paginationContainer: document.getElementById('paginationContainer'),
      prevPageBtn: document.getElementById('prevPageBtn'),
      nextPageBtn: document.getElementById('nextPageBtn'),
      pageInfoText: document.getElementById('pageInfoText'),
      
      toast: document.getElementById('toast'),
      showAdminBtn: document.getElementById('showAdminBtn'),
      adminModal: document.getElementById('adminModal'),
      adminCode: document.getElementById('adminCode'),
      cancelAdminBtn: document.getElementById('cancelAdminBtn'),
      submitAdminBtn: document.getElementById('submitAdminBtn'),
      adminSection: document.getElementById('adminSection'),
      fileUpload: document.getElementById('fileUpload'),
      cloudStatus: document.getElementById('cloudStatus')
    };

    // 顯示提示訊息
    let toastTimeout;
    function showMessage(msg) {
      els.toast.textContent = msg;
      els.toast.classList.remove('opacity-0');
      clearTimeout(toastTimeout);
      toastTimeout = setTimeout(() => {
        els.toast.classList.add('opacity-0');
      }, 3000);
    }

    // 初始化職級選單
    function initRankSelect() {
      RANK_OPTIONS.forEach(opt => {
        const option = document.createElement('option');
        option.value = opt.name;
        option.textContent = opt.name;
        els.rank.appendChild(option);
      });
      els.rank.value = '業務經理';
    }

    // 更新計算結果
    function updateCalculations() {
      const feeVal = Number(els.fee.value) || 0;
      const rateVal = Number(els.agentRate.value) || 0;
      const kVal = Number(els.kValue.value) || 0;

      const fycValue = feeVal * (rateVal / 100);
      const cNumber = fycValue / 10000;
      const salary = fycValue * (kVal / 100);

      els.currentFycText.textContent = `${Math.round(fycValue).toLocaleString()} 元`;
      els.currentCText.textContent = `${cNumber.toFixed(2)} C`;
      els.currentSalaryText.textContent = `${Math.round(salary).toLocaleString()} 元`;

      return { fycValue, cNumber, salary };
    }

    // 自動帶入費率邏輯
    function checkAutoFill() {
      const pName = els.productName.value;
      const pTerm = String(els.term.value);
      
      if (catalog.length > 0 && pName && pTerm) {
        const match = catalog.find(c => c.name === pName && c.term === pTerm);
        if (match) {
          els.agentRate.value = match.rate;
          els.agentRate.classList.remove('border-gray-300');
          els.agentRate.classList.add('border-green-300', 'bg-green-50');
          els.autoFillBadge.classList.remove('hidden');
          updateCalculations();
          return;
        }
      }
      
      // 取消自動帶入狀態
      els.agentRate.classList.add('border-gray-300');
      els.agentRate.classList.remove('border-green-300', 'bg-green-50');
      els.autoFillBadge.classList.add('hidden');
    }

    // 更新下拉提示清單
    function updateDatalist() {
      const uniqueNames = [...new Set(catalog.map(c => c.name))];
      els.productList.innerHTML = '';
      uniqueNames.forEach(name => {
        const option = document.createElement('option');
        option.value = name;
        els.productList.appendChild(option);
      });
    }

    // 渲染清單與分頁
    function renderRecords() {
      const totalPages = Math.ceil(records.length / ITEMS_PER_PAGE) || 1;
      if (currentPage > totalPages) currentPage = totalPages;

      // 總計
      const totalC = records.reduce((sum, r) => sum + r.cNumber, 0);
      const totalS = records.reduce((sum, r) => sum + r.salary, 0);
      els.totalCText.textContent = `${totalC.toFixed(2)} C`;
      els.totalSalaryText.textContent = `${Math.round(totalS).toLocaleString()} 元`;

      if (records.length === 0) {
        els.emptyListState.classList.remove('hidden');
        els.recordsContainer.classList.add('hidden');
        els.paginationContainer.classList.add('hidden');
        return;
      }

      els.emptyListState.classList.add('hidden');
      els.recordsContainer.classList.remove('hidden');
      
      // 渲染列表內容
      const start = (currentPage - 1) * ITEMS_PER_PAGE;
      const currentRecords = records.slice(start, start + ITEMS_PER_PAGE);
      
      els.recordsContainer.innerHTML = '';
      currentRecords.forEach(record => {
        const div = document.createElement('div');
        div.className = 'p-4 border border-gray-100 rounded-lg hover:bg-gray-50 flex justify-between items-center transition-colors';
        div.innerHTML = `
          <div class="space-y-1">
            <div class="font-medium text-gray-900">
              ${record.productName} (${record.term}年期)
              <span class="text-xs text-gray-500 ml-2 bg-gray-100 px-2 py-0.5 rounded">
                ${record.rank} (K值 ${record.kValue}%)
              </span>
            </div>
            <div class="text-sm text-gray-500">
              保費: ${record.fee.toLocaleString()} 元 | 代理率: ${record.agentRate}% | FYC: ${record.cNumber.toFixed(2)} C
            </div>
          </div>
          <div class="flex items-center space-x-4">
            <div class="text-right">
              <div class="text-sm text-gray-500">薪水</div>
              <div class="font-bold text-gray-900">${Math.round(record.salary).toLocaleString()} 元</div>
            </div>
            <button class="text-red-400 hover:text-red-600 p-1 delete-btn" data-id="${record.id}" title="刪除此筆紀錄">✕</button>
          </div>
        `;
        els.recordsContainer.appendChild(div);
      });

      // 綁定刪除事件
      document.querySelectorAll('.delete-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const id = Number(e.currentTarget.getAttribute('data-id'));
          records = records.filter(r => r.id !== id);
          renderRecords();
        });
      });

      // 處理分頁控制顯示
      if (records.length > ITEMS_PER_PAGE) {
        els.paginationContainer.classList.remove('hidden');
        els.paginationContainer.classList.add('flex');
        els.pageInfoText.textContent = `第 ${currentPage} 頁，共 ${totalPages} 頁`;
        els.prevPageBtn.disabled = currentPage === 1;
        els.nextPageBtn.disabled = currentPage === totalPages;
      } else {
        els.paginationContainer.classList.add('hidden');
        els.paginationContainer.classList.remove('flex');
      }
    }

    // 新增紀錄
    function handleAddRecord() {
      const feeVal = Number(els.fee.value);
      const rateVal = Number(els.agentRate.value);
      const kVal = Number(els.kValue.value);

      if (!feeVal || !rateVal || !kVal) {
        showMessage('請填寫費用、代理率與K值');
        return;
      }

      const calcs = updateCalculations();
      
      const newRecord = {
        id: Date.now(),
        productName: els.productName.value || '未命名商品',
        term: Number(els.term.value),
        fee: feeVal,
        agentRate: rateVal,
        rank: els.rank.value,
        kValue: kVal,
        fycValue: calcs.fycValue,
        cNumber: calcs.cNumber,
        salary: calcs.salary
      };

      records.push(newRecord);
      
      // 清空部分輸入，保留職級、代理率供連續輸入
      els.productName.value = '';
      els.fee.value = '';
      els.agentRate.classList.add('border-gray-300');
      els.agentRate.classList.remove('border-green-300', 'bg-green-50');
      els.autoFillBadge.classList.add('hidden');
      updateCalculations();
      renderRecords();
    }

    // 解析 CSV 邏輯
    function parseCSV(str) {
      const arr = [];
      let quote = false, row = [], col = '';
      for (let c = 0; c < str.length; c++) {
        let cc = str[c], nc = str[c + 1];
        if (cc === '"' && quote && nc === '"') { col += cc; c++; continue; }
        if (cc === '"') { quote = !quote; continue; }
        if (cc === ',' && !quote) { row.push(col); col = ''; continue; }
        if (cc === '\n' && !quote) { row.push(col); col = ''; arr.push(row); row = []; continue; }
        if (cc === '\r' && !quote) { continue; }
        col += cc;
      }
      if (col !== '' || row.length > 0) { row.push(col); arr.push(row); }
      return arr;
    }

    // 處理 CSV 上傳
    function handleFileUpload(e) {
      const file = e.target.files[0];
      if (!file) return;

      if (file.name.endsWith('.xlsx') || file.name.endsWith('.xls')) {
        showMessage('工具目前僅支援 CSV 格式。請將 Excel 另存為 CSV 檔案後再上傳。');
        e.target.value = '';
        return;
      }

      const processText = async (text) => {
        const rows = parseCSV(text);
        if (rows.length < 2) return false;

        let headerRowIdx = -1, nameIdx = -1, termIdx = -1, rateIdx = -1;

        for (let i = 0; i < Math.min(50, rows.length); i++) {
          const rowText = rows[i].map(h => typeof h === 'string' ? h.replace(/\s+/g, '') : '');
          nameIdx = rowText.findIndex(h => h.includes('險種名稱'));
          termIdx = rowText.findIndex(h => h.includes('年期'));
          rateIdx = rowText.findIndex(h => h.includes('佣金第1年') || h.includes('代理費') || h.includes('佣金'));
          if (nameIdx !== -1 && rateIdx !== -1) { headerRowIdx = i; break; }
        }

        if (headerRowIdx === -1) return false;

        const newCatalog = [];
        for (let i = headerRowIdx + 1; i < rows.length; i++) {
          const row = rows[i];
          if (row.length > Math.max(nameIdx, rateIdx)) {
            const name = row[nameIdx]?.trim();
            if (!name) continue;

            const termStr = termIdx !== -1 ? (row[termIdx]?.trim() || '') : '';
            let termNum = termStr.replace(/\D/g, ''); 
            if (termStr.includes('躉')) termNum = '1';

            let rateStr = row[rateIdx]?.replace(/%/g, '')?.trim();
            const rate = parseFloat(rateStr);

            if (name && !isNaN(rate)) {
              newCatalog.push({ name, term: termNum || '1', rate });
            }
          }
        }

        if (newCatalog.length > 0) {
          if (db && auth && auth.currentUser) {
            try {
              const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'rateConfig', 'catalog');
              await setDoc(docRef, { rates: JSON.stringify(newCatalog), updatedAt: Date.now() });
              showMessage('✅ 費率表已成功上傳至雲端！所有人皆已同步。');
            } catch (error) {
              console.error(error);
              showMessage('❌ 雲端上傳失敗，請稍後再試。');
            }
          } else {
            // 本地模式備用
            catalog = newCatalog;
            updateDatalist();
            showMessage('✅ (本地模式) 費率表載入成功。');
          }
          return true;
        }
        return false;
      };

      const reader = new FileReader();
      reader.onload = async (event) => {
        const success = await processText(event.target.result);
        if (!success) {
          const readerBig5 = new FileReader();
          readerBig5.onload = async (e2) => {
            const successBig5 = await processText(e2.target.result);
            if (!successBig5) showMessage('❌ 匯入失敗：找不到對應的欄位「險種名稱」或「佣金第1年」。');
          };
          readerBig5.readAsText(file, 'Big5');
        } else {
          e.target.value = ''; 
        }
      };
      reader.readAsText(file, 'utf-8');
    }

    // 事件監聽綁定
    function attachEventListeners() {
      // 數字輸入框攔截滾輪事件
      [els.term, els.fee, els.agentRate].forEach(input => {
        input.addEventListener('wheel', (e) => e.target.blur());
      });

      // 即時計算綁定
      [els.fee, els.agentRate, els.kValue].forEach(input => {
        input.addEventListener('input', updateCalculations);
      });

      // 自動帶入綁定
      [els.productName, els.term].forEach(input => {
        input.addEventListener('input', () => {
          checkAutoFill();
          updateCalculations();
        });
      });

      // 手動修改代理率取消帶入標記
      els.agentRate.addEventListener('input', () => {
        els.agentRate.classList.add('border-gray-300');
        els.agentRate.classList.remove('border-green-300', 'bg-green-50');
        els.autoFillBadge.classList.add('hidden');
      });

      // 職級切換
      els.rank.addEventListener('change', (e) => {
        const matched = RANK_OPTIONS.find(opt => opt.name === e.target.value);
        if (matched) {
          els.kValue.value = matched.k;
          updateCalculations();
        }
      });

      // 按鈕綁定
      els.addRecordBtn.addEventListener('click', handleAddRecord);
      
      els.prevPageBtn.addEventListener('click', () => {
        currentPage = Math.max(1, currentPage - 1);
        renderRecords();
      });
      els.nextPageBtn.addEventListener('click', () => {
        const totalPages = Math.ceil(records.length / ITEMS_PER_PAGE);
        currentPage = Math.min(totalPages, currentPage + 1);
        renderRecords();
      });

      // 管理員控制
      els.showAdminBtn.addEventListener('click', () => els.adminModal.classList.remove('hidden'));
      els.cancelAdminBtn.addEventListener('click', () => els.adminModal.classList.add('hidden'));
      els.submitAdminBtn.addEventListener('click', () => {
        if (els.adminCode.value === '19970923') {
          isAdmin = true;
          els.adminModal.classList.add('hidden');
          els.adminSection.classList.remove('hidden');
          els.adminSection.classList.add('flex');
          showMessage('✅ 管理員模式已解鎖');
        } else {
          showMessage('❌ 密碼錯誤');
        }
        els.adminCode.value = '';
      });

      els.fileUpload.addEventListener('change', handleFileUpload);
    }

    // 初始化 Firebase Auth 與資料同步
    function initFirebase() {
      if (!auth || !db) {
        els.cloudStatus.innerHTML = '<span class="text-gray-500">僅本地端運行模式</span>';
        return;
      }

      const login = async () => {
        try {
          if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
            await signInWithCustomToken(auth, __initial_auth_token);
          } else {
            await signInAnonymously(auth);
          }
        } catch (error) {
          console.error("登入失敗", error);
        }
      };

      login();

      onAuthStateChanged(auth, (u) => {
        user = u;
        if (user) {
          const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'rateConfig', 'catalog');
          onSnapshot(docRef, (snap) => {
            if (snap.exists()) {
              try {
                catalog = JSON.parse(snap.data().rates);
                updateDatalist();
                els.cloudStatus.innerHTML = `<span class="text-green-600 font-medium">✅ 雲端費率庫已連線 (${catalog.length} 筆商品)</span>`;
              } catch (e) {
                console.error("解析費率表失敗", e);
              }
            } else {
              els.cloudStatus.innerHTML = '<span class="text-gray-400">目前雲端無費率資料，請聯絡管理員上傳</span>';
            }
          }, (error) => {
            console.error("讀取雲端資料失敗", error);
          });
        }
      });
    }

    // 啟動應用程式
    function initApp() {
      initRankSelect();
      updateCalculations();
      attachEventListeners();
      renderRecords();
      initFirebase();
    }

    initApp();

  </script>
</body>
</html>
